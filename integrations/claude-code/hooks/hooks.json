{
  "description": "Privacy-safe root-session lifecycle hooks for thoth-mem.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/runners/hook-runner.mjs\" --harness claude --hook SessionStart",
            "timeout": 10,
            "statusMessage": "Loading thoth-mem context..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/runners/hook-runner.mjs\" --harness claude --hook UserPromptSubmit",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/runners/hook-runner.mjs\" --harness claude --hook PreCompact",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/runners/hook-runner.mjs\" --harness claude --hook Stop",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
