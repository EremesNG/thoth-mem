{
  "name": "thoth-mem",
  "version": "0.2.0",
  "type": "module",
  "description": "Persistent memory MCP server for AI coding agents",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EremesNG/thoth-mem.git"
  },
  "homepage": "https://github.com/EremesNG/thoth-mem#readme",
  "bugs": {
    "url": "https://github.com/EremesNG/thoth-mem/issues"
  },
  "main": "dist/index.js",
  "bin": {
    "thoth-mem": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && npm run dashboard:build",
    "dashboard:build": "npm run build --prefix dashboard",
    "dashboard:typecheck": "npm run typecheck --prefix dashboard",
    "dev": "tsx watch src/index.ts",
    "eval:retrieval": "tsx src/evals/retrieval.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "memory",
    "ai",
    "coding-agent",
    "sqlite",
    "persistent-memory"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^12.8.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
