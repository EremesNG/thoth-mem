{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://unpkg.com/thoth-mem/config.schema.json",
  "title": "Thoth-Mem Config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Public JSON Schema URL for Thoth-Mem config files."
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "maxContentLength": {
      "type": "integer",
      "minimum": 1
    },
    "maxContextChars": {
      "type": "integer",
      "minimum": 0,
      "description": "Output character budget for context and project-summary renders. Set 0 to disable the output cap explicitly."
    },
    "maxContextResults": {
      "type": "integer",
      "minimum": 1
    },
    "maxSearchResults": {
      "type": "integer",
      "minimum": 1
    },
    "dedupeWindowMinutes": {
      "type": "integer",
      "minimum": 0
    },
    "previewLength": {
      "type": "integer",
      "minimum": 0
    },
    "http": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "disabled": {
          "type": "boolean"
        }
      }
    },
    "graphFactsSource": {
      "type": "string",
      "enum": ["legacy", "kg"],
      "description": "Graph-facts source switch used for observation_facts rollback during KG consolidation."
    },
    "retrievalDefaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sentenceTopK": {
          "type": "integer",
          "minimum": 1
        },
        "chunkTopK": {
          "type": "integer",
          "minimum": 1
        },
        "lexicalLimit": {
          "type": "integer",
          "minimum": 1
        },
        "minSemanticScore": {
          "type": "number",
          "minimum": 0
        },
        "l2DistanceScale": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "embedding": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["transformers_local", "ollama", "lmstudio"]
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "baseUrl": {
          "type": ["string", "null"]
        },
        "dimensions": {
          "type": ["integer", "null"],
          "minimum": 1
        }
      }
    },
    "hyde": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "provider": {
          "type": "string",
          "enum": ["transformers_local", "ollama", "lmstudio"]
        },
        "model": {
          "type": ["string", "null"]
        },
        "baseUrl": {
          "type": ["string", "null"]
        },
        "timeoutMs": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "kgLlm": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "provider": {
          "type": "string",
          "enum": ["transformers_local", "ollama", "lmstudio"]
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "baseUrl": {
          "type": ["string", "null"]
        },
        "timeoutMs": {
          "type": "integer",
          "minimum": 1
        },
        "minContentChars": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "knowledgeGraph": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kgMultiHopEnabled": {
          "type": "boolean"
        },
        "kgMaxDepth": {
          "type": "integer",
          "minimum": 1
        },
        "kgNeighborhoodLimit": {
          "type": "integer",
          "minimum": 1
        },
        "kgMultiHopWeight": {
          "type": "number",
          "minimum": 0
        },
        "kgDepthDecay": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        },
        "kgTraversalTimeoutMs": {
          "type": "integer",
          "minimum": 0
        },
        "kgSupersedeEnabled": {
          "type": "boolean",
          "description": "Enables KG supersession detection, marking, deprioritization, and current-state graph views."
        },
        "kgSupersedeContentPatterns": {
          "type": "boolean",
          "description": "Enables optional lower-confidence content-pattern supersession hints."
        },
        "kgSupersedeConfidenceThreshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Minimum confidence for optional content-pattern supersession hints."
        },
        "kgSupersedeDeprioritizeWeight": {
          "type": "number",
          "minimum": 0,
          "description": "Score multiplier applied to superseded KG evidence during retrieval."
        },
        "kgPruneEnabled": {
          "type": "boolean",
          "description": "Enables automatic keep-N pruning of old superseded KG triples during supersession writes."
        },
        "kgSupersededKeepN": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of most-recent superseded KG triples retained per source/subject/relation slot."
        },
        "kgPruneOrphanEntities": {
          "type": "boolean",
          "description": "Removes KG entities left with no referencing triples after a superseded-triple prune."
        },
        "kgRelationAllowList": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "USES",
              "DEPENDS_ON",
              "BELONGS_TO",
              "PART_OF",
              "OWNS",
              "CONFIGURES",
              "IMPLEMENTS",
              "RUNS_IN",
              "DEPLOYS_TO",
              "CAUSES",
              "FIXES",
              "BLOCKS",
              "UNBLOCKS",
              "AFFECTS",
              "REFERENCES",
              "MENTIONS",
              "EXTRACTED_FROM",
              "HAS_TOPIC",
              "HAS_SCOPE",
              "PRECEDES",
              "FOLLOWS",
              "AUTHENTICATES_WITH",
              "HAS_WHAT",
              "HAS_WHY",
              "HAS_WHERE",
              "HAS_LEARNED",
              "SUPERSEDES"
            ]
          }
        }
      }
    }
  }
}
